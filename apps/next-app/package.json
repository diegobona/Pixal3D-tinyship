{
  "name": "@tinyship/next-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 7001",
    "build": "next build",
    "build:cf": "node ../../scripts/opennext-cloudflare.mjs build",
    "preview:cf": "node ../../scripts/opennext-cloudflare.mjs build && node ../../scripts/opennext-cloudflare.mjs preview --port 7001",
    "deploy:cf": "node ../../scripts/opennext-cloudflare.mjs build && node ../../scripts/opennext-cloudflare.mjs deploy --keep-vars",
    "start": "NODE_ENV=production next start --port 7001",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/model-viewer": "4.2.0",
    "clsx": "2.1.1",
    "dotenv": "^16.4.5",
    "next": "16.2.6",
    "pg-cloudflare": "1.4.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "3.0.2",
    "three": "0.182.0",
    "tw-animate-css": "1.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/postcss": "4.1.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "postcss": "8.5.6",
    "postcss-import": "16.1.0",
    "tailwindcss": "^4.0.15",
    "wrangler": "4.93.0"
  }
}
